<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/lightGray"
    android:fillViewport="true"
    tools:context=".dailyearn.ui.view.DailyEarnFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CardView 1: Spin and Win -->
        <androidx.cardview.widget.CardView
            android:id="@+id/spin_and_win_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardElevation="8dp"
            android:background="@android:color/white"
            app:cardCornerRadius="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- ImageView with Rounded Corners -->
                <ImageView
                    android:id="@+id/spin_and_win_image"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/spin_wheel"
                    android:scaleType="centerCrop"
                    android:background="@drawable/rounded_corners"
                    android:contentDescription="Spin and Win" />

                <!-- Text and Badge -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/spin_and_win_image"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="48dp">

                    <TextView
                        android:id="@+id/tv_spin_the_wheel_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spin and Win"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_spin_the_wheel_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Try your luck and win rewards"
                        android:textSize="14sp"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginTop="4dp" />

                    <!-- Bar showing times left -->
                    <ProgressBar
                        android:id="@+id/spin_and_win_bar"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="48dp"
                        android:progressDrawable="@drawable/progress_bar_style"
                        android:max="10"
                        android:progress="1"
                        android:indeterminate="false"
                        style="?android:attr/progressBarStyleHorizontal"/>

                    <TextView
                        android:id="@+id/tv_spin_the_wheel_next_bonus_in"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next in 23h 23min"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Arrow Icon -->
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_forward_24"
                    android:contentDescription="Arrow"
                    app:tint="@color/blue" />

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
