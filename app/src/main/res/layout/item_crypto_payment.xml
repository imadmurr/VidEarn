<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    android:layout_marginBottom="0dp"
    app:cardElevation="10dp"
    app:cardCornerRadius="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/item_payment_content_marginBottom">

        <!-- Badge for the status -->
        <TextView
            android:id="@+id/tv_crypto_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/shape_badge_red_background"
            android:padding="4dp"
            android:text="Pending.."
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Delete Icon below the badge -->
        <ImageView
            android:id="@+id/img_btn_delete_payment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_crypto_status"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_delete_payment"
            android:contentDescription="@string/delete_payment" />

        <!-- Image of the payment on the left -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_payment_image"
            android:layout_width="@dimen/item_payment_image_size"
            android:layout_height="@dimen/item_payment_image_size"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@string/image_contentDescription"
            android:src="@drawable/ic_user_place_holder"
            app:civ_border_color="@color/blue"
            app:civ_border_width="@dimen/item_payment_image_circular_border_width" />

        <!-- Text Layout for Amount, Coin, and Network -->
        <LinearLayout
            android:id="@+id/amount_and_coin_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_payment_image"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <!-- Amount -->
            <TextView
                android:id="@+id/tv_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text_color"
                android:textSize="@dimen/item_payment_amount_text_size"
                tools:text="Amount: 10 000" />

            <!-- Coin and Network on the same line -->
            <TextView
                android:id="@+id/tv_coin_and_network"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text_color"
                android:textSize="@dimen/item_payment_amount_text_size"
                tools:text="Coin: USDT - Polygon" />

        </LinearLayout>

        <!-- Address remains below the text block -->
        <TextView
            android:id="@+id/tv_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/amount_and_coin_layout"
            android:layout_alignStart="@id/amount_and_coin_layout"
            android:layout_marginTop="8dp"
            android:textColor="@color/secondary_text_color"
            android:textSize="@dimen/item_payment_address_text_size"
            android:maxEms="10"
            tools:text="Address: 123456789012345678901234567890123456789012" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>
