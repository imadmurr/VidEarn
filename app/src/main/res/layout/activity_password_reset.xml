<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/lightGray"
    tools:context=".auth.ui.view.PasswordResetActivity">

    <!-- Header Frame with Circle Image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="273dp"
        android:background="@drawable/blue_bg"
        android:id="@+id/header_frame">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@mipmap/ic_launcher"/>
    </FrameLayout>

    <!-- Verification Instruction Text -->
    <TextView
        android:id="@+id/tv_reset_your_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_frame"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="48dp"
        android:text="@string/reset_your_password"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:gravity="center"
        android:textStyle="bold" />

    <!-- Email Input Field -->
    <LinearLayout
        android:id="@+id/email_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_reset_your_password"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="48dp"
        android:orientation="horizontal"
        android:background="@drawable/rounded_corners"
        android:padding="10dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/email"
            android:layout_gravity="center_vertical"/>

        <EditText
            android:id="@+id/email_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_gravity="center_vertical"
            android:hint="Email"
            android:background="@null"
            android:inputType="textEmailAddress"/>
    </LinearLayout>

    <!-- Login Button -->
    <Button
        android:id="@+id/reset_password_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/email_input_layout"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="48dp"
        android:text="Reset Password"
        android:background="@drawable/shape_button_rounded"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"/>

</RelativeLayout>
